{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --ignore-scripts --filter @workspace/finer-build...",
  "buildCommand": "pnpm --filter @workspace/finer-build build",
  "outputDirectory": "artifacts/finer-build/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
